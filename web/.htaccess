# jardyx.com — Apache error-document configuration.
#
# This file is a self-contained drop-in for the jardyx.com web root.
# It assumes the sibling HTML files in this directory are deployed to
# /.error/jardyx.com/ on the target server (i.e. the directory layout
# from the repo is preserved).

# ---- Custom error documents (Jardyx CI) --------------------------------
ErrorDocument 400 /error/400.html
ErrorDocument 401 /error/401.html
ErrorDocument 403 /error/403.html
ErrorDocument 404 /error/404.html
ErrorDocument 500 /error/500.html
ErrorDocument 502 /error/502.html
ErrorDocument 503 /error/503.html
ErrorDocument 504 /error/504.html

# ---- Allow Apache to serve from this hidden directory -----------------
# Some distros ship a global rule denying any path starting with a dot.
Require all granted
Options -Indexes

# ---- Error pages must not be cached aggressively ----------------------
<IfModule mod_headers.c>
    Header set Cache-Control "no-cache, must-revalidate"
</IfModule>
